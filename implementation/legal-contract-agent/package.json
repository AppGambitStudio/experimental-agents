{
  "name": "legal-contract-agent",
  "version": "0.1.0",
  "description": "AI-powered Indian contract review agent — flags risks against Indian law, generates negotiation playbooks, tracks versions",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "concurrently --names server,web --prefix-colors blue,green \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx --watch server/index.ts",
    "dev:web": "cd web && npm run dev",
    "analyze": "tsx src/cli.ts",
    "copilot": "tsx src/copilot-cli.ts",
    "test-tools": "tsx src/test-tools.ts",
    "test": "node --import tsx --test src/tests/*.test.ts server/tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "keywords": [
    "ai-agent",
    "contract-review",
    "indian-law",
    "claude-agent-sdk",
    "legal-tech"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.84",
    "@hono/node-server": "^1.19.11",
    "@types/node": "^25.5.0",
    "@types/pdf-parse": "^1.1.5",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "hono": "^4.12.9",
    "pdf-parse": "^2.4.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "zod": "^4.3.6"
  }
}
